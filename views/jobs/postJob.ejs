<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Post Job – HireFlow</title>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <span class="logo-text">HireFlow</span>
      <small>Recruiter Portal</small>
    </div>

    <nav class="sidebar-nav">
      <a href="/recruiter/dashboard" class="nav-item">
        <span class="nav-icon">📊</span>
        Dashboard
      </a>
      <a href="/post-job" class="nav-item active">
        <span class="nav-icon">➕</span>
        Post a Job
      </a>
      <a href="/recruiter/profile" class="nav-item">
        <span class="nav-icon">👤</span>
        My Profile
      </a>
      <a href="/logout" class="nav-item nav-logout" style="margin-top: auto;">
        <span class="nav-icon">🚪</span>
        Logout
      </a>
    </nav>

    <div class="sidebar-bottom">
      <a href="/recruiter/profile" style="text-decoration: none; color: inherit; display: block;">
        <div class="user-pill">
          <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
          <div>
            <div class="user-name"><%= user.name %></div>
            <div class="user-role">Hiring Manager</div>
          </div>
        </div>
      </a>
    </div>
  </aside>

  <main class="main" style="background: url('/images/recruiter_bg.png') no-repeat center center fixed; background-size: cover; min-height: 100vh; position: relative;">
    <!-- Overlay for better readability -->
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(2px); z-index: 0;"></div>
    
    <div style="position: relative; z-index: 1;">
      <div>
        <h1 style="font-size: 28px; letter-spacing: -1px;">Post a New Opportunity 🚀</h1>
        <p>Connect with the best candidates on HireFlow.</p>
      </div>
    </div>

    <div style="display: flex; justify-content: center; padding-top: 20px;">
      <div class="card" style="max-width: 700px; width: 100%; padding: 48px; border-radius: 24px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.3); box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);">
        
        <form method="POST" action="/post-job">
          <div style="display: flex; flex-direction: column; gap: 28px;">
            
            <div style="display: flex; flex-direction: column; gap: 8px;">
              <label style="font-size: 14px; font-weight: 700; color: #1e293b;">Job Title</label>
              <input type="text" name="title" placeholder="e.g. Senior Software Engineer" required
                     style="padding: 16px; border: 2px solid #e2e8f0; border-radius: 14px; font-size: 16px; transition: all 0.2s; outline: none;" 
                     onfocus="this.style.borderColor='#6366f1'; this.style.boxShadow='0 0 0 4px rgba(99, 102, 241, 0.1)'"
                     onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none'">
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
              <div style="display: flex; flex-direction: column; gap: 8px;">
                <label style="font-size: 14px; font-weight: 700; color: #1e293b;">Company</label>
                <input type="text" name="company" placeholder="Company Name" required
                       style="padding: 16px; border: 2px solid #e2e8f0; border-radius: 14px; font-size: 16px; outline: none;">
              </div>
              <div style="display: flex; flex-direction: column; gap: 8px;">
                <label style="font-size: 14px; font-weight: 700; color: #1e293b;">Location</label>
                <input type="text" name="location" placeholder="Remote / City" required
                       style="padding: 16px; border: 2px solid #e2e8f0; border-radius: 14px; font-size: 16px; outline: none;">
              </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
              <div style="display: flex; flex-direction: column; gap: 8px;">
                <label style="font-size: 14px; font-weight: 700; color: #1e293b;">Salary Range</label>
                <input type="text" name="salary" placeholder="e.g. ₹10 - 15 LPA"
                       style="padding: 16px; border: 2px solid #e2e8f0; border-radius: 14px; font-size: 16px; outline: none;">
              </div>
              <div style="display: flex; flex-direction: column; gap: 8px;">
                <label style="font-size: 14px; font-weight: 700; color: #1e293b;">Job Type</label>
                <select name="jobType" required style="padding: 16px; border: 2px solid #e2e8f0; border-radius: 14px; font-size: 16px; background: #fff; outline: none;">
                  <option value="Full Time">Full Time</option>
                  <option value="Part Time">Part Time</option>
                  <option value="Internship">Internship</option>
                  <option value="Remote">Remote</option>
                </select>
              </div>
            </div>

            <div style="display: flex; flex-direction: column; gap: 8px;">
              <label style="font-size: 14px; font-weight: 700; color: #1e293b;">Job Description</label>
              <textarea name="description" rows="6" placeholder="What are the roles and responsibilities?" required
                        style="padding: 16px; border: 2px solid #e2e8f0; border-radius: 14px; font-size: 16px; resize: vertical; line-height: 1.6; outline: none;"></textarea>
            </div>

            <div style="margin-top: 10px;">
              <button type="submit" class="btn btn-primary" style="width: 100%; padding: 18px; font-size: 16px; font-weight: 800; border-radius: 16px; background: linear-gradient(135deg, #6366f1, #4f46e5); border: none; box-shadow: 0 10px 20px -5px rgba(79, 70, 229, 0.4); cursor: pointer; transition: all 0.3s;">
                Publish Job Listing
              </button>
            </div>

          </div>
        </form>

        <div style="text-align: center; margin-top: 24px;">
          <a href="/recruiter/dashboard" style="color: #64748b; font-size: 14px; font-weight: 600; text-decoration: none;">Cancel and return to dashboard</a>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
