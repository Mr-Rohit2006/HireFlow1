<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login – HireFlow</title>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>

<div class="auth-container">
  <div class="auth-side-image">
    <div class="auth-image-content">
      <h2>Find Your Dream Job</h2>
      <p>Join thousands of professionals and take the next step in your career journey with HireFlow.</p>
    </div>
  </div>

  <div class="auth-side-form">
    <form class="auth-card" method="POST" action="/login">
      <h2>Welcome Back 👋</h2>
      <p>Please enter your details to sign in</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert-error">
          <span>⚠️</span> <%= error %>
        </div>
      <% } %>

      <div style="display: flex; flex-direction: column; gap: 4px; margin-bottom: 20px;">
        <label style="font-size: 13px; font-weight: 700; color: var(--text);">Email Address</label>
        <input type="email" name="email" placeholder="name@company.com" 
               value="<%= (typeof formData !== 'undefined' && formData.email) ? formData.email : '' %>" required>
      </div>

      <div style="display: flex; flex-direction: column; gap: 4px; margin-bottom: 20px;">
        <label style="font-size: 13px; font-weight: 700; color: var(--text);">Password</label>
        <div class="password-wrapper">
          <input type="password" name="password" id="passwordInput" placeholder="••••••••" required>
          <span class="eye-icon" onclick="togglePassword()">
            <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </span>
        </div>
      </div>

      <div class="remember-row">
        <label class="remember-label">
          <input type="checkbox" name="rememberMe" value="on">
          Keep me logged in
        </label>
        <a href="/forgot-password" class="forgot-link">Forgot Password?</a>
      </div>

      <button type="submit">Sign In</button>

      <p class="switch">New to HireFlow? <a href="/register">Create an account</a></p>
    </form>
  </div>
</div>

<script>
  function togglePassword() {
    const input = document.getElementById("passwordInput");
    const icon  = document.getElementById("eyeIcon");
    if (input.type === "password") {
      input.type = "text";
      icon.innerHTML = `
        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
        <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
        <line x1="1" y1="1" x2="23" y2="23"/>
      `;
    } else {
      input.type = "password";
      icon.innerHTML = `
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      `;
    }
  }
</script>

</body>
</html>
