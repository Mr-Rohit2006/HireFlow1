<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password – HireFlow</title>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>

<div class="auth-container">
  <div class="auth-side-image" style="background-image: url('/images/forgot_pw.png');">
    <div class="auth-image-content">
      <h2>Secure Your Account</h2>
      <p>Don't worry, we'll help you get back into your account in no time.</p>
    </div>
  </div>

  <div class="auth-side-form">
    <form class="auth-card" method="POST" action="/forgot-password">
      <h2>Forgot Password? 🔑</h2>
      <p>Enter your email address and we'll send you a link to reset your password.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert-error">
          <span>⚠️</span> <%= error %>
        </div>
      <% } %>

      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert-success">
          <span>✅</span> <%= success %>
        </div>
      <% } %>

      <div style="display: flex; flex-direction: column; gap: 4px; margin-bottom: 24px;">
        <label style="font-size: 13px; font-weight: 700; color: var(--text);">Email Address</label>
        <input type="email" name="email" placeholder="e.g. name@company.com" required>
      </div>

      <button type="submit">Send Reset Link</button>

      <p class="switch"><a href="/login">← Back to Login</a></p>
    </form>
  </div>
</div>

</body>
</html>
