<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password – HireFlow</title>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>

<div class="auth-container">
  <div class="auth-side-image" style="background-image: url('/images/reset_pw.png');">
    <div class="auth-image-content">
      <h2>Secure Your Future</h2>
      <p>A strong password is the first step towards securing your professional journey.</p>
    </div>
  </div>

  <div class="auth-side-form">
    <div class="auth-card">
      <h2>Reset Password 🔒</h2>
      <p>Please enter your new password below to regain access.</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert-error">
          <span>⚠️</span> <%= error %>
        </div>
      <% } %>

      <% if (token) { %>
        <form method="POST" action="/reset-password">
          <input type="hidden" name="token" value="<%= token %>">

          <div style="display: flex; flex-direction: column; gap: 4px; margin-bottom: 24px;">
            <label style="font-size: 13px; font-weight: 700; color: var(--text);">New Password</label>
            <div class="password-wrapper">
              <input type="password" name="password" id="passwordInput" placeholder="Minimum 6 characters" minlength="6" required>
              <span class="eye-icon" onclick="togglePassword()">
                <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              </span>
            </div>
          </div>

          <button type="submit">Update Password</button>
        </form>
      <% } else { %>
        <div class="alert-error" style="text-align: center;">
          <p>This reset link is invalid or has expired.</p>
        </div>
        <a href="/forgot-password" class="btn btn-primary" style="text-decoration: none; display: block; text-align: center; margin-top: 10px;">Request New Link</a>
      <% } %>

      <p class="switch"><a href="/login">← Back to Login</a></p>
    </div>
  </div>
</div>

<script>
  function togglePassword() {
    const input = document.getElementById("passwordInput");
    const icon  = document.getElementById("eyeIcon");
    if (input.type === "password") {
      input.type = "text";
      icon.innerHTML = `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>`;
    } else {
      input.type = "password";
      icon.innerHTML = `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
    }
  }
</script>

</body>
</html>
