<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Job – HireFlow</title>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <span class="logo-text">HireFlow</span>
      <small>Recruiter Portal</small>
    </div>

    <nav class="sidebar-nav">
      <a href="/recruiter/dashboard" class="nav-item">
        <span class="nav-icon">📊</span>
        Dashboard
      </a>
      <a href="/post-job" class="nav-item">
        <span class="nav-icon">➕</span>
        Post a Job
      </a>
      <a href="/recruiter/profile" class="nav-item">
        <span class="nav-icon">👤</span>
        My Profile
      </a>
      <a href="/logout" class="nav-item nav-logout" style="margin-top: auto;">
        <span class="nav-icon">🚪</span>
        Logout
      </a>
    </nav>

    <div class="sidebar-bottom">
      <a href="/recruiter/profile" style="text-decoration: none; color: inherit; display: block;">
        <div class="user-pill">
          <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
          <div>
            <div class="user-name"><%= user.name %></div>
            <div class="user-role">Hiring Manager</div>
          </div>
        </div>
      </a>
    </div>
  </aside>

  <main class="main" style="background: url('/images/recruiter_bg.png') no-repeat center center fixed; background-size: cover; min-height: 100vh; position: relative;">
    <!-- Overlay for better readability -->
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(4px); z-index: 0;"></div>
    
    <div style="position: relative; z-index: 1;">
    <div class="topbar">
      <h1>Edit Job Listing</h1>
      <p>Update job details for <%= job.title %></p>
    </div>

    <div class="card" style="max-width: 800px;">
      <% if (typeof error !== 'undefined' && error) { %>
        <div style="background: #fee2e2; color: #991b1b; padding: 12px 16px; border-radius: 8px; margin-bottom: 24px; font-weight: 600; font-size: 14px; border: 1px solid #fecaca;">
          ⚠️ <%= error %>
        </div>
      <% } %>

      <form action="/recruiter/job/<%= job._id %>/edit" method="POST">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
          
          <div class="form-group" style="grid-column: span 2; display: flex; flex-direction: column; gap: 8px;">
            <label style="font-size: 13px; font-weight: 700; color: var(--text);">Job Title *</label>
            <input type="text" name="title" value="<%= job.title %>" placeholder="e.g. Frontend Developer" required
                   style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
          </div>

          <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
            <label style="font-size: 13px; font-weight: 700; color: var(--text);">Company Name *</label>
            <input type="text" name="company" value="<%= job.company %>" placeholder="e.g. Google" required
                   style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
          </div>

          <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
            <label style="font-size: 13px; font-weight: 700; color: var(--text);">Location *</label>
            <input type="text" name="location" value="<%= job.location %>" placeholder="e.g. Remote / Delhi" required
                   style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
          </div>

          <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
            <label style="font-size: 13px; font-weight: 700; color: var(--text);">Job Type</label>
            <select name="type" style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; background: #fff;">
              <option value="Full-time" <%= job.type === 'Full-time' ? 'selected' : '' %>>Full-time</option>
              <option value="Part-time" <%= job.type === 'Part-time' ? 'selected' : '' %>>Part-time</option>
              <option value="Internship" <%= job.type === 'Internship' ? 'selected' : '' %>>Internship</option>
              <option value="Remote" <%= job.type === 'Remote' ? 'selected' : '' %>>Remote</option>
              <option value="Contract" <%= job.type === 'Contract' ? 'selected' : '' %>>Contract</option>
            </select>
          </div>

          <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
            <label style="font-size: 13px; font-weight: 700; color: var(--text);">Salary / Stipend</label>
            <input type="text" name="salary" value="<%= job.salary || '' %>" placeholder="e.g. ₹5 LPA / ₹15,000/mo"
                   style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
          </div>

          <div class="form-group" style="grid-column: span 2; display: flex; flex-direction: column; gap: 8px;">
            <label style="font-size: 13px; font-weight: 700; color: var(--text);">Skills Required</label>
            <input type="text" name="skills" value="<%= job.skills || '' %>" placeholder="e.g. Node.js, React, MongoDB"
                   style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
          </div>

          <div class="form-group" style="grid-column: span 2; display: flex; flex-direction: column; gap: 8px;">
            <label style="font-size: 13px; font-weight: 700; color: var(--text);">Job Description *</label>
            <textarea name="description" rows="6" placeholder="Describe the role, responsibilities..." required
                      style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; resize: vertical;"><%= job.description %></textarea>
          </div>

          <div style="grid-column: span 2; display: flex; gap: 16px; margin-top: 12px;">
            <button type="submit" class="btn btn-primary" style="flex: 1; padding: 14px;">Save Changes</button>
            <a href="/recruiter/dashboard" class="btn" style="flex: 1; padding: 14px; background: #fff; border: 1px solid var(--border); color: var(--text-muted); text-align: center; text-decoration: none;">Cancel</a>
          </div>
        </div>
      </form>
    </div>
    </div>
  </main>
</div>
</body>
</html>
