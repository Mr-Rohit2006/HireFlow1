<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recruiter Dashboard – HireFlow</title>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/recruiter-dashboard.css">
</head>
<body>

<div class="layout">

  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <span class="logo-text">HireFlow</span>
      <small>Recruiter Portal</small>
    </div>

    <nav class="sidebar-nav">
      <a href="/recruiter/dashboard" class="nav-item active">
        <span class="nav-icon">📊</span>
        Dashboard
      </a>
      <a href="/post-job" class="nav-item">
        <span class="nav-icon">➕</span>
        Post a Job
      </a>
      <a href="/recruiter/profile" class="nav-item">
        <span class="nav-icon">👤</span>
        My Profile
      </a>
      <a href="/logout" class="nav-item nav-logout" style="margin-top: auto;">
        <span class="nav-icon">🚪</span>
        Logout
      </a>
    </nav>

    <div class="sidebar-bottom">
      <a href="/recruiter/profile" style="text-decoration: none; color: inherit; display: block;">
        <div class="user-pill">
          <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
          <div>
            <div class="user-name"><%= user.name %></div>
            <div class="user-role">Hiring Manager</div>
          </div>
        </div>
      </a>
    </div>
  </aside>

  <!-- Main -->
  <main class="main" style="background: url('/images/recruiter_bg.png') no-repeat center center fixed; background-size: cover; min-height: 100vh; position: relative;">
    <!-- Overlay for better readability -->
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(4px); z-index: 0;"></div>
    
    <div style="position: relative; z-index: 1;">
    <!-- Topbar -->
    <div class="topbar">
      <div>
        <h1>Recruiter Dashboard</h1>
        <p>Welcome back! Here's what's happening with your job listings today.</p>
      </div>
      <a href="/post-job" class="btn btn-primary" style="padding: 12px 24px; display: flex; align-items: center; gap: 8px;">
        <span>➕</span> Post New Job
      </a>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px; margin-bottom: 32px;">
      <div class="card stat-card" style="padding: 24px; display: flex; align-items: center; gap: 20px;">
        <div style="width: 56px; height: 56px; background: #eef2ff; color: #4f46e5; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 24px;">💼</div>
        <div>
          <div style="font-size: 14px; font-weight: 600; color: var(--text-muted); margin-bottom: 4px;">Active Jobs</div>
          <div style="font-size: 28px; font-weight: 800; color: var(--text); line-height: 1;"><%= totalJobs %></div>
        </div>
      </div>
      <div class="card stat-card" style="padding: 24px; display: flex; align-items: center; gap: 20px;">
        <div style="width: 56px; height: 56px; background: #fdf2f8; color: #db2777; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 24px;">👥</div>
        <div>
          <div style="font-size: 14px; font-weight: 600; color: var(--text-muted); margin-bottom: 4px;">Total Applicants</div>
          <div style="font-size: 28px; font-weight: 800; color: var(--text); line-height: 1;"><%= totalApplications %></div>
        </div>
      </div>
      <div class="card stat-card" style="padding: 24px; display: flex; align-items: center; gap: 20px;">
        <div style="width: 56px; height: 56px; background: #f0fdf4; color: #16a34a; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 24px;">⚡</div>
        <div>
          <div style="font-size: 14px; font-weight: 600; color: var(--text-muted); margin-bottom: 4px;">Avg. Response</div>
          <div style="font-size: 28px; font-weight: 800; color: var(--text); line-height: 1;">24h</div>
        </div>
      </div>
    </div>

    <!-- Main Content Row -->
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
      
      <!-- Jobs Management -->
      <div class="card" style="padding: 0; overflow: hidden;">
        <div style="padding: 24px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
          <h2 style="font-size: 18px; font-weight: 700; margin: 0;">My Job Listings</h2>
          <span style="font-size: 12px; font-weight: 700; background: var(--bg); padding: 4px 10px; border-radius: 20px; color: var(--text-muted); border: 1px solid var(--border);"><%= jobs.length %> Total</span>
        </div>

        <div style="overflow-x: auto;">
          <% if (jobs.length === 0) { %>
            <div style="padding: 60px; text-align: center;">
              <div style="font-size: 48px; margin-bottom: 16px;">📂</div>
              <h3 style="margin-bottom: 8px;">No jobs posted yet</h3>
              <p style="color: var(--text-muted); margin-bottom: 24px;">Start hiring by posting your first job listing.</p>
              <a href="/post-job" class="btn btn-primary">Post Your First Job</a>
            </div>
          <% } else { %>
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
              <thead>
                <tr style="background: #f9fafb;">
                  <th style="padding: 16px 24px; font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase;">Job Details</th>
                  <th style="padding: 16px 24px; font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase;">Status</th>
                  <th style="padding: 16px 24px; font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; text-align: right;">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% jobs.forEach(job => { %>
                  <tr style="border-bottom: 1px solid var(--border); transition: background 0.2s;" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background='transparent'">
                    <td style="padding: 20px 24px;">
                      <div style="font-weight: 700; color: var(--text); margin-bottom: 4px;"><%= job.title %></div>
                      <div style="font-size: 13px; color: var(--text-muted); display: flex; align-items: center; gap: 8px;">
                        <span>📍 <%= job.location %></span>
                        <span>•</span>
                        <span>💰 <%= job.salary || 'Not Disclosed' %></span>
                      </div>
                    </td>
                    <td style="padding: 20px 24px;">
                      <span style="display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: #dcfce7; color: #166534;">Active</span>
                    </td>
                    <td style="padding: 20px 24px; text-align: right;">
                      <div style="display: flex; gap: 8px; justify-content: flex-end;">
                        <a href="/recruiter/job/<%= job._id %>/applicants" class="btn" style="padding: 8px 12px; font-size: 12px; background: #eef2ff; color: #4f46e5; border: none; font-weight: 700;">👥 Applicants</a>
                        <a href="/recruiter/job/<%= job._id %>/edit" class="btn" style="padding: 8px 12px; font-size: 12px; background: var(--bg); color: var(--text); border: 1px solid var(--border); font-weight: 700;">✏️ Edit</a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

      <!-- Side Column -->
      <div style="display: flex; flex-direction: column; gap: 24px;">
        <!-- Quick Stats Summary -->
        <div class="card" style="padding: 24px;">
          <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 20px;">Hiring Overview</h3>
          <div style="display: flex; flex-direction: column; gap: 16px;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span style="font-size: 14px; color: var(--text-muted);">Published Jobs</span>
              <span style="font-weight: 700;"><%= totalJobs %></span>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span style="font-size: 14px; color: var(--text-muted);">Total Candidates</span>
              <span style="font-weight: 700;"><%= totalApplications %></span>
            </div>
          </div>
        </div>

        <!-- Tips Card -->
        <div class="card" style="padding: 24px; background: linear-gradient(135deg, #4f46e5, #4338ca); color: #fff; border: none;">
          <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 12px;">Hiring Tip 💡</h3>
          <p style="font-size: 14px; opacity: 0.9; line-height: 1.5; margin-bottom: 16px;">
            Clear job descriptions and quick responses to candidates can improve your hiring rate by 40%.
          </p>
          <a href="/post-job" style="color: #fff; font-size: 13px; font-weight: 700; text-decoration: underline;">Post more jobs</a>
        </div>
      </div>

    </div>
    </div>
  </main>
</div>

</body>
</html>
