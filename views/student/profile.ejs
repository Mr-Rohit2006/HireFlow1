<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>My Profile – HireFlow</title>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

<div class="layout">

  <aside class="sidebar">
    <div class="sidebar-logo">
      <span class="logo-text">HireFlow</span>
      <small>Student Portal</small>
    </div>

    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-item">Dashboard</a>
      <a href="/jobs" class="nav-item">Browse Jobs</a>
      <a href="/my-applications" class="nav-item">My Applications</a>
      <a href="/saved-jobs" class="nav-item">Saved Jobs</a>
      <a href="/profile" class="nav-item active">My Profile</a>
      <a href="/logout" class="nav-item nav-logout">Logout</a>
    </nav>

    <div class="sidebar-bottom">
      <div class="user-pill">
        <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
        <div>
          <div class="user-name"><%= user.name %></div>
          <div class="user-role">Student</div>
        </div>
      </div>
    </div>
  </aside>

  <main class="main" style="background: url('/images/student_bg.png') no-repeat center center fixed; background-size: cover; min-height: 100vh; position: relative;">
    <!-- Overlay for better readability -->
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(4px); z-index: 0;"></div>
    
    <div style="position: relative; z-index: 1;">

    <div class="topbar">
      <h1>My Profile</h1>
      <p>Manage your account settings and preferences</p>
    </div>

    <div class="profile-wrap" style="max-width: 800px;">

      <% if(typeof success !== 'undefined' && success){ %>
        <div style="background: #dcfce7; color: #166534; padding: 12px 16px; border-radius: 8px; margin-bottom: 24px; font-weight: 600; font-size: 14px; border: 1px solid #bbf7d0;">
          ✓ <%= success %>
        </div>
      <% } %>

      <% if(typeof error !== 'undefined' && error){ %>
        <div style="background: #fee2e2; color: #991b1b; padding: 12px 16px; border-radius: 8px; margin-bottom: 24px; font-weight: 600; font-size: 14px; border: 1px solid #fecaca;">
          ⚠️ <%= error %>
        </div>
      <% } %>

      <div class="card" style="padding: 0; overflow: hidden;">
        <div style="background: linear-gradient(to right, var(--primary), var(--secondary)); height: 100px;"></div>
        
        <div style="padding: 0 32px 32px;">
          <div style="display: flex; align-items: flex-end; gap: 20px; margin-top: -40px; margin-bottom: 32px;">
            <div class="avatar" style="width: 100px; height: 100px; font-size: 40px; border: 6px solid #fff; box-shadow: var(--shadow-md);">
              <%= user.name.charAt(0).toUpperCase() %>
            </div>
            <div style="padding-bottom: 8px;">
              <h2 style="font-size: 24px; font-weight: 800; color: var(--text);"><%= user.name %></h2>
              <p style="color: var(--text-muted); font-size: 14px;"><%= user.email %></p>
            </div>
          </div>

          <form method="POST" action="/profile" enctype="multipart/form-data">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
              
              <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                <label style="font-size: 13px; font-weight: 700; color: var(--text);">Full Name</label>
                <input type="text" name="name" value="<%= user.name || '' %>" required 
                       style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
              </div>

              <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                <label style="font-size: 13px; font-weight: 700; color: var(--text);">Email Address</label>
                <input type="email" value="<%= user.email %>" disabled 
                       style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; background: var(--bg); color: var(--text-faint);">
              </div>

              <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                <label style="font-size: 13px; font-weight: 700; color: var(--text);">Phone Number</label>
                <input type="text" name="phone" value="<%= user.phone || '' %>" placeholder="+91 00000 00000"
                       style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
              </div>

              <div class="form-group" style="display: flex; flex-direction: column; gap: 8px;">
                <label style="font-size: 13px; font-weight: 700; color: var(--text);">Key Skills</label>
                <input type="text" name="skills" value="<%= user.skills || '' %>" placeholder="e.g. React, Node.js, Python"
                       style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px;">
              </div>

              <div class="form-group" style="grid-column: span 2; display: flex; flex-direction: column; gap: 8px;">
                <label style="font-size: 13px; font-weight: 700; color: var(--text);">Bio / Professional Summary</label>
                <textarea name="bio" placeholder="Tell recruiters about yourself..."
                          style="padding: 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; min-height: 120px; resize: vertical;"><%= user.bio || '' %></textarea>
              </div>

              <div class="form-group" style="grid-column: span 2; padding: 20px; background: var(--bg); border: 1px dashed var(--border); border-radius: 12px;">
                <label style="font-size: 14px; font-weight: 700; color: var(--text); display: block; margin-bottom: 12px;">Upload Latest Resume (PDF)</label>
                <input type="file" name="resume" accept=".pdf" style="font-size: 13px;">
                
                <% if(user.resume){ %>
                  <div style="margin-top: 12px; display: flex; align-items: center; gap: 8px;">
                    <span style="color: var(--green);">📄</span>
                    <a href="/<%= user.resume.replace(/\\/g, '/') %>" target="_blank" style="color: var(--primary); font-weight: 600; font-size: 13px; text-decoration: underline;">
                      View Current Resume
                    </a>
                  </div>
                <% } %>
              </div>

            </div>

            <button type="submit" class="btn btn-primary" style="margin-top: 32px; padding: 14px 32px; font-size: 15px; width: auto;">
              Save Changes
            </button>
          </form>
        </div>
      </div>

    </div>
    </div>
  </main>

</div>

</body>
</html>