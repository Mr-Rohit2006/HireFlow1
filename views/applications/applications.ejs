<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Applications – HireFlow</title>
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

<div class="layout">

  <aside class="sidebar">
    <div class="sidebar-logo">
      <span class="logo-text">HireFlow</span>
      <small>Student Portal</small>
    </div>

    <nav class="sidebar-nav">
      <a href="/dashboard" class="nav-item">Dashboard</a>
      <a href="/jobs" class="nav-item">Browse Jobs</a>
      <a href="/my-applications" class="nav-item active">My Applications</a>
      <a href="/saved-jobs" class="nav-item">Saved Jobs</a>
      <a href="/profile" class="nav-item">My Profile</a>
      <a href="/logout" class="nav-item nav-logout">Logout</a>
    </nav>

    <div class="sidebar-bottom">
      <div class="user-pill">
        <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
        <div>
          <div class="user-name"><%= user.name %></div>
          <div class="user-role">Student</div>
        </div>
      </div>
    </div>
  </aside>

  <main class="main" style="background: url('/images/student_bg.png') no-repeat center center fixed; background-size: cover; min-height: 100vh; position: relative;">
    <!-- Overlay for better readability -->
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(4px); z-index: 0;"></div>
    
    <div style="position: relative; z-index: 1;">

    <div class="topbar">
      <div>
        <h1>My Applications</h1>
        <p>Track all your applied jobs</p>
      </div>

      <span class="badge-new">
        <%= applications.length %> Total
      </span>
    </div>

    <% if(applications.length === 0){ %>

      <div class="empty" style="margin-top: 40px;">
        <div style="font-size: 48px; margin-bottom: 16px;">📂</div>
        <h3>No applications yet!</h3>
        <p>Your job applications will appear here once you start applying.</p>
        <a href="/jobs" class="btn btn-primary" style="margin-top: 20px; display: inline-block;">Browse Jobs & Apply</a>
      </div>

    <% } else { %>

      <div class="cards" style="margin-top: 32px; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));">
        <% applications.forEach(app => { %>
          <div class="card" style="padding: 24px; border-radius: 20px; display: flex; flex-direction: column; gap: 20px; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
            
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
              <div style="width: 50px; height: 50px; background: #eef2ff; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px;">🏢</div>
              <span class="badge 
                <%= app.status === 'Shortlisted' ? 'shortlisted' : '' %>
                <%= app.status === 'Rejected' ? 'rejected' : '' %>
                <%= app.status === 'Pending' || !app.status ? 'pending' : '' %>
              ">
                <%= app.status || "Pending" %>
              </span>
            </div>

            <div>
              <h3 style="font-size: 18px; font-weight: 800; color: var(--text); margin-bottom: 4px;"><%= app.job.title %></h3>
              <div style="font-size: 14px; font-weight: 600; color: var(--primary);"><%= app.job.company %></div>
              <div style="font-size: 13px; color: var(--text-muted); margin-top: 8px; display: flex; align-items: center; gap: 4px;">
                <span>📍 <%= app.job.location %></span>
              </div>
            </div>

            <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 16px; border-top: 1px solid #f1f5f9;">
              <div style="font-size: 12px; color: var(--text-muted);">
                Applied on: <b><%= new Date(app.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short' }) %></b>
              </div>
              <% if(app.resume){ %>
                <a href="/uploads/resumes/<%= app.resume %>" target="_blank" style="font-size: 13px; font-weight: 700; color: var(--primary); text-decoration: none; display: flex; align-items: center; gap: 4px;">
                  📄 Resume
                </a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>

    <% } %>

    </div>
  </main>

</div>

</body>
</html>